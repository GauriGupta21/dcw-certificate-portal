# --- SECURITY HARDENING ---

# 1. Disable Directory Browsing
Options -Indexes

# 2. Hide Server Signature
ServerSignature Off

# 3. Protect Configuration and Hidden Files
<FilesMatch "^(config\.php|\.htaccess|\.env|\.git)">
    Require all denied
</FilesMatch>

# 4. HTTP Security Headers
<IfModule mod_headers.c>
    # Prevent Clickjacking
    Header set X-Frame-Options "SAMEORIGIN"
    # Prevent MIME-sniffing
    Header set X-Content-Type-Options "nosniff"
    # Enable XSS Protection in older browsers
    Header set X-XSS-Protection "1; mode=block"
    # Referrer Policy
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# --- ROUTING & URL REWRITES ---

RewriteEngine On

# Force HTTPS (Uncomment below lines if SSL is installed)
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Clean URL for Verification
RewriteRule ^verify/([a-zA-Z0-9_-]+)$ verify.php?id=$1 [L,QSA]

# --- PERFORMANCE CACHING ---
<IfModule mod_expires.c>
    ExpiresActive On
    
    # Images
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
    
    # CSS, JavaScript
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType text/javascript "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    
    # Others
    ExpiresByType application/pdf "access plus 1 month"
    ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
    <filesMatch "\.(ico|jpe?g|png|gif|swf|webp|svg)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </filesMatch>
    <filesMatch "\.(css|js)$">
        Header set Cache-Control "public, max-age=2592000"
    </filesMatch>
</IfModule>
